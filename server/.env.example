# Libera server configuration — copy to .env and fill in. Never commit .env.

# Port the API + realtime server listens on
PORT=3001

# Public URL of the web client (used in verification / password-reset emails)
PUBLIC_URL=http://localhost:5173

# REQUIRED in production: long random string used to protect sessions
SESSION_SECRET=

# Database file location (defaults to server/data/libera.db)
# DB_PATH=/var/lib/libera/libera.db
# UPLOADS_DIR=/var/lib/libera/uploads

# --- Email (optional in development) ---
# When unset, verification/reset emails are logged to the console and exposed at
# GET /api/dev/mailbox?email=... (development only) so flows remain testable.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Libera <no-reply@example.com>"

# --- WebRTC (optional) ---
# A public STUN server is used by default. For calls across strict NATs,
# configure a TURN server and it will be passed to clients.
# TURN_URL=turn:turn.example.com:3478
# TURN_USER=
# TURN_PASS=
